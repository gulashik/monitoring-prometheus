{{/* ===== Заголовок Slack-сообщения ===== */}}
{{ define "slack.custom.title" -}}
  [{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .CommonLabels.alertname }}
{{- end }}

{{/* ===== Тело Slack-сообщения ===== */}}
{{ define "slack.custom.text" -}}
  {{ range .Alerts -}}
    *Severity:* `{{ .Labels.severity }}`
    *Summary:* {{ .Annotations.summary }}
    *Description:* {{ .Annotations.description }}
    *Instance:* {{ .Labels.instance }}
    *Started:* {{ .StartsAt.Format "2006-01-02 15:04:05" }}
    {{ if ne .Status "firing" }}*Resolved:* {{ .EndsAt.Format "2006-01-02 15:04:05" }}{{ end }}
  {{ end }}
{{- end }}

{{/* ===== Цвет вложения (danger / warning / good) ===== */}}
{{ define "slack.custom.color" -}}
  {{ if eq .Status "firing" -}}
    {{ if eq .CommonLabels.severity "critical" -}}danger
    {{- else if eq .CommonLabels.severity "warning" -}}warning
    {{- else -}}#439FE0{{- end }}
  {{- else -}}good{{- end }}
{{- end }}