{{ define "email.custom.subject" -}}
  [{{ .Status | toUpper }}] {{ .CommonLabels.alertname }} ({{ .Alerts.Firing | len }} firing)
{{- end }}

{{ define "email.custom.html" -}}
<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; color: #333; }
    .alert { border-left: 5px solid #ccc; padding: 10px 15px; margin: 10px 0; background: #f9f9f9; }
    .firing { border-color: #e01e5a; }
    .resolved { border-color: #2eb67d; }
    .label { display: inline-block; background: #eee; border-radius: 3px; padding: 1px 6px; margin: 2px; font-size: 12px; }
    h2 { margin-bottom: 5px; }
    .meta { color: #888; font-size: 12px; }
  </style>
</head>
<body>
  <h2>{{ .CommonLabels.alertname }} — {{ .Status | toUpper }}</h2>

  {{ range .Alerts }}
  <div class="alert {{ if eq .Status "firing" }}firing{{ else }}resolved{{ end }}">
    <strong>{{ .Annotations.summary }}</strong>
    <p>{{ .Annotations.description }}</p>
    <p class="meta">
      Severity: <b>{{ .Labels.severity }}</b><br>
      Instance: {{ .Labels.instance }}<br>
      Started: {{ .StartsAt.Format "2006-01-02 15:04:05 MST" }}
      {{ if ne .Status "firing" }}<br>Resolved: {{ .EndsAt.Format "2006-01-02 15:04:05 MST" }}{{ end }}
    </p>
    <div>
      {{ range .Labels.SortedPairs }}<span class="label">{{ .Name }}={{ .Value }}</span>{{ end }}
    </div>
  </div>
  {{ end }}
</body>
</html>
{{- end }}